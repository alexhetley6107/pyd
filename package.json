{
  "name": "pyd",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:web": "npm run dev -w @pyd/web",
    "dev:server": "npm run dev -w @pyd/server",
    "dev": "npm run dev:server & npm run dev:web",
    "build:web": "npm run build -w @pyd/web",
    "build:server": "npm run build -w @pyd/server",
    "build": "npm run build:server && npm run build:web",
    "format": "prettier --write \"apps/*/src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"apps/*/src/**/*.{ts,html,scss,json}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "overrides": {
    "typescript": "5.7.3",
    "rxjs": "7.8.2"
  }
}
